TEST_AUTH_PROVIDER=password

# Password flow
TEST_USER_EMAIL=your-test-user@example.com
TEST_USER_PASSWORD=replace-me

# Google flow
# Set TEST_AUTH_PROVIDER=google to use this path.
# TEST_GOOGLE_EMAIL defaults to TEST_USER_EMAIL if omitted.
TEST_GOOGLE_EMAIL=your-google-login@example.com
TEST_GOOGLE_PASSWORD=replace-me

            "size": 1877,
            "mimeType": "application/json",
            "text": "{\"document\":{\"id\":\"bb718cf8-20a8-4080-93a7-1bdc55a1bc21\",\"scope\":\"global\",\"status\":\"published\",\"version\":2,\"principles\":\"Jevn oppbygning i kilometer frem mot peak formtopping tre til seks uker før konkurranse.\",\"dos\":\"Pendling med tog mandag, tirsdag og onsdag med to økter tur retur toget (6,5 km hver vei).\\nLangtur søndag. Kan også legge opp langtur lørdag om det trengs back to back.\",\"donts\":\"Dobbel terskel ikke i spesifikk periode\",\"workout_examples\":\"# 20-30 x 45/15 på mølle\\n# Progressiv langtur (5 min/km -> 4:15 min/km)'\\n# Tempoøkt 3 x variabel km, f.eks 3-5 km (totalt 15-20 km)\",\"phase_notes\":\"# Base: Flere kortintervall (45/15) enn i spesifikk periode\",\"koop_weight\":50,\"bakken_weight\":50,\"changelog_note\":\"Etablert plan\",\"published_at\":\"2026-03-06T08:13:15.628+00:00\",\"published_by\":\"252afd05-d117-4d18-9842-09f8a7f65ff4\",\"created_at\":\"2026-03-06T08:13:07.859489+00:00\",\"created_by\":\"252afd05-d117-4d18-9842-09f8a7f65ff4\",\"updated_at\":\"2026-03-06T08:13:15.628+00:00\",\"updated_by\":\"252afd05-d117-4d18-9842-09f8a7f65ff4\"},\"versions\":[{\"id\":\"f8eed53f-79f6-4ae1-9fb9-839b1ee570a7\",\"version\":2,\"source\":\"publish\",\"principles\":\"Jevn oppbygning i kilometer frem mot peak formtopping tre til seks uker før konkurranse.\",\"dos\":\"Pendling med tog mandag, tirsdag og onsdag med to økter tur retur toget (6,5 km hver vei).\\nLangtur søndag. Kan også legge opp langtur lørdag om det trengs back to back.\",\"donts\":\"Dobbel terskel ikke i spesifikk periode\",\"workout_examples\":\"# 20-30 x 45/15 på mølle\\n# Progressiv langtur (5 min/km -> 4:15 min/km)'\\n# Tempoøkt 3 x variabel km, f.eks 3-5 km (totalt 15-20 km)\",\"phase_notes\":\"# Base: Flere kortintervall (45/15) enn i spesifikk periode\",\"koop_weight\":50,\"bakken_weight\":50,\"changelog_note\":\"Etablert plan\",\"published_by\":\"252afd05-d117-4d18-9842-09f8a7f65ff4\",\"published_at\":\"2026-03-06T08:13:15.628+00:00\"}]}"
